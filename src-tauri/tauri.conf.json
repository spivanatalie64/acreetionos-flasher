{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/refs/heads/main/tauri.conf.json",
  "productName": "AcreetionOS USB Flasher",
  "version": "1.0.0",
  "identifier": "org.acreetionos.flasher",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node generate-editions.js",
    "frontendDist": "../src"
  },
  "app": {
    "title": "AcreetionOS USB Flasher",
    "windows": [
      {
        "title": "AcreetionOS USB Flasher",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
